[Unit]
Description=Trading Bot - Leveraged ETF Momentum Paper
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=trader
WorkingDirectory=/home/trader/trading-bot
EnvironmentFile=/home/trader/trading-bot/.env
ExecStart=/home/trader/trading-bot/.venv/bin/python /home/trader/trading-bot/main.py momentum-paper
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
